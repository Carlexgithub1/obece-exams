<%- include("partials/_header", {title:`${typeof exam !== "undefined" ? exam.title.toUpperCase() : null}`}) %>

<div class="wrapper">
    <%- include("components/title", {msg: `${typeof exam !== "undefined" ? exam.title.toUpperCase() + " - ": null}Selectionnez une serie (ou specialite)`}) %>
    <main class="main">
        <div class="section-search">
            <a href="/" class="home-btn btn">
                <img src="/ico/home.svg" alt="Search icon" srcset="">
            </a>
            <input type="text" name="search" id="search-box" class="search-box" placeholder="Rechercher une epreuve">
            <button class="search-btn">
                <img src="/ico/search.svg" alt="Search icon" srcset="">
            </button>
        </div>
        <div class="section-content">
            <ul class="series-list list">

                <% if (typeof exam !== "undefined") { %>

                    <% exam.series.forEach(seriecategory => { %>
                        <p class="serie-category">
                            <%= seriecategory.type.charAt(0).toUpperCase() + seriecategory.type.slice(1) %>
                        </p>

                        <% seriecategory.series.sort((a, b) => a.serie.localeCompare(b.serie)).forEach(serie => { %>
                            <a 
                            href="<%= serie.link %>"
                            class="session-link session-item list-item <%if (serie.link.length <= 2){ %>disabled<% } %>"
                            target="_blank" rel="noopener noreferrer"                            
                            >
                                <li class="">
                                    <%= serie.serie %> <%= serie.speciality %> 
                                </li>
                            </a>
                        <% }) %>  

                    <% }) %> 
                <% } else { %>
                    <li class="no-sessions list-item disabled" disabled>Aucune serie disponible.</li>
                <% } %>
                                
            </ul>
        </div>
    </main>
</div>

<%- include("partials/_footer") %>